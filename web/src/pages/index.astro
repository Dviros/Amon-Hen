---
import { Font } from "astro:assets";
import {
  authorName,
  defaultSiteUrl,
  description,
  examplePrompt,
  ogImageAlt,
  ogImagePath,
  siteName,
  title,
} from "../site-meta.js";
import "../styles/global.css";

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? defaultSiteUrl;
const pageUrl = `${siteUrl}/`;
const metaImage = `${siteUrl}${ogImagePath}`;
const repoUrl = "https://github.com/Dviros/Amon-Hen";
const docsUrl = `${repoUrl}/blob/main/crates/council/README.md`;
const licenseUrl = `${repoUrl}/blob/main/LICENSE`;
const crateName = "council";
const crateVersion = "0.1.5";
const crateUrl = `https://crates.io/crates/${crateName}`;
const robotsContent = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: siteUrl,
    description,
    inLanguage: "en-US",
    publisher: {
      "@type": "Person",
      name: authorName,
      url: "https://github.com/Dviros",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: siteName,
    url: pageUrl,
    description,
    mainEntityOfPage: pageUrl,
    applicationCategory: "DeveloperApplication",
    applicationSubCategory: "Command-line interface",
    softwareVersion: crateVersion,
    downloadUrl: crateUrl,
    softwareHelp: {
      "@type": "CreativeWork",
      url: docsUrl,
    },
    runtimePlatform: "Native Rust binary",
    softwareRequirements: "Authenticated Codex, Claude, or Gemini CLI installed locally",
    license: licenseUrl,
    image: metaImage,
    author: {
      "@type": "Person",
      name: authorName,
      url: "https://github.com/Dviros",
    },
    isAccessibleForFree: true,
    keywords: "Codex, Claude, Gemini, Linear, AI agents, Rust CLI, terminal UI",
    featureList: [
      "Native Rust orchestration for Codex, Claude, and Gemini",
      "Interactive Studio with auth, provider capabilities, telemetry, prompt file tags, and command tools",
      "Provider-specific model, effort, sandbox, MCP, Skills, tools, and permission controls",
      "Long-running Linear delivery loops with isolated workspaces, retries, reconciliation, media, and review or CI gates",
      "Team-work fanout that lets each provider run same-provider sub-agents",
    ],
    sameAs: [repoUrl, crateUrl],
  },
]);

const providerRows = [
  ["Codex", "/agent-logos/codex.png", "planner", "gpt-5.2", "high", "inherit MCP profile"],
  ["Claude", "/agent-logos/claude.png", "lead", "sonnet", "max", "override tools"],
  ["Gemini", "/agent-logos/gemini.svg", "executor", "gemini-pro", "high", "settings profile"],
];

const workflowCards = [
  ["Studio first", "Move panes, change roles, tag files, onboard auth, inspect tools, and rerun without leaving the terminal."],
  ["Provider-native", "Inherit each CLI's local config by default, then override MCP, Skills, tools, model, effort, or permissions when the task needs it."],
  ["Linear loop", "Poll selected projects or epics, isolate each issue workspace, retry failures, reconcile state, and stop at review or passing CI."],
  ["Observable agents", "See prompt commands, shell tools, token usage, sub-agent fanout, provider status, and final synthesis in one place."],
];

const linearSteps = [
  ["Target", "Select Linear projects, epics, labels, teams, or explicit issue IDs."],
  ["Plan", "Assign planner, lead, and executors with phase-specific provider prompts."],
  ["Work", "Create isolated workspaces, run tools, attach media, and comment progress back to Linear."],
  ["Gate", "Reconcile retries and finish only at human review or GitHub CI success."],
];

const capabilityFlags = [
  "--codex-config",
  "--codex-mcp-profile",
  "--claude-mcp-config",
  "--claude-allowed-tools",
  "--claude-disallowed-tools",
  "--gemini-settings",
  "--gemini-tools-profile",
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/amonhen.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#10251f" />
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    <meta name="author" content={authorName} />
    <meta name="creator" content={authorName} />
    <meta name="publisher" content={authorName} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <link rel="canonical" href={pageUrl} />
    <link rel="sitemap" type="application/xml" href={`${siteUrl}/sitemap.xml`} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:image:secure_url" content={metaImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={metaImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-geist-mono" preload />
    <script type="application/ld+json" set:html={structuredData}></script>
    <script is:inline>
      if (window.matchMedia("(prefers-reduced-motion: no-preference)").matches) {
        document.documentElement.classList.add("motion-pending");
        window.requestAnimationFrame(() => {
          window.requestAnimationFrame(() => {
            document.documentElement.classList.remove("motion-pending");
            document.documentElement.classList.add("motion-ready");
          });
        });
      }
    </script>
    <style is:global>
      html {
        scroll-behavior: smooth;
        background: #f6f7f2;
      }

      body {
        margin: 0;
        min-width: 320px;
        background: #f6f7f2;
        color: #10251f;
        font-family: var(--font-inter), system-ui, sans-serif;
        text-rendering: geometricPrecision;
      }

      * {
        box-sizing: border-box;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page-shell {
        min-height: 100vh;
        overflow: hidden;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid rgba(16, 37, 31, 0.16);
        background: rgba(246, 247, 242, 0.92);
        backdrop-filter: blur(14px);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1180px;
        height: 68px;
        margin: 0 auto;
        padding: 0 24px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-weight: 800;
        line-height: 1;
      }

      .brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: #10251f;
        color: #d8b45f;
        font-size: 0.82rem;
        font-weight: 800;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 22px;
        color: #30453e;
        font-size: 0.95rem;
        font-weight: 650;
      }

      .nav-links a {
        border-bottom: 2px solid transparent;
      }

      .nav-links a:hover {
        border-bottom-color: #d8b45f;
      }

      .section {
        max-width: 1180px;
        margin: 0 auto;
        padding: 96px 24px;
      }

      .hero {
        position: relative;
        border-bottom: 1px solid rgba(16, 37, 31, 0.14);
      }

      .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(90deg, rgba(16, 37, 31, 0.07) 1px, transparent 1px),
          linear-gradient(180deg, rgba(16, 37, 31, 0.07) 1px, transparent 1px);
        background-size: 56px 56px;
        mask-image: linear-gradient(180deg, #000 0%, transparent 82%);
        pointer-events: none;
      }

      .hero-grid {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(460px, 1.08fr);
        align-items: center;
        gap: 54px;
        min-height: calc(100vh - 68px);
        max-width: 1180px;
        margin: 0 auto;
        padding: 68px 24px 78px;
      }

      .eyebrow {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        gap: 10px;
        margin-bottom: 26px;
        padding: 8px 12px;
        border: 1px solid rgba(16, 37, 31, 0.22);
        border-radius: 8px;
        background: #ffffff;
        color: #30453e;
        font-size: 0.82rem;
        font-weight: 800;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 10px;
        height: 10px;
        border-radius: 3px;
        background: #2f7d69;
        box-shadow: 16px 0 0 #b7472a, 32px 0 0 #315fb5;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        max-width: 780px;
        color: #10251f;
        font-size: 4.7rem;
        font-weight: 850;
        line-height: 0.98;
        letter-spacing: 0;
      }

      .hero-copy {
        margin-top: 26px;
        max-width: 690px;
        color: #30453e;
        font-size: 1.22rem;
        font-weight: 520;
        line-height: 1.68;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 34px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        padding: 0 18px;
        border: 2px solid #10251f;
        border-radius: 8px;
        font-size: 0.96rem;
        font-weight: 800;
        line-height: 1;
      }

      .button.primary {
        background: #10251f;
        color: #f6f7f2;
      }

      .button.secondary {
        background: #ffffff;
        color: #10251f;
      }

      .button:hover {
        transform: translateY(-1px);
        box-shadow: 5px 5px 0 #d8b45f;
      }

      .command {
        margin-top: 34px;
        max-width: 720px;
        border: 2px solid #10251f;
        border-radius: 8px;
        background: #101312;
        color: #e8ede4;
        box-shadow: 10px 10px 0 #2f7d69;
        overflow: hidden;
      }

      .command-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(246, 247, 242, 0.18);
        padding: 10px 14px;
        color: #a7b5ae;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.82rem;
      }

      .command pre {
        margin: 0;
        overflow-x: auto;
        padding: 18px;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.92rem;
        line-height: 1.75;
        white-space: pre-wrap;
      }

      .studio-frame {
        border: 2px solid #10251f;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 14px 14px 0 #d8b45f;
        overflow: hidden;
      }

      .studio-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 2px solid #10251f;
        background: #10251f;
        color: #f6f7f2;
        padding: 12px 14px;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.82rem;
      }

      .studio-status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      .studio-status::before {
        content: "";
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: #d8b45f;
      }

      .studio-layout {
        display: grid;
        grid-template-columns: 220px minmax(0, 1fr);
        min-height: 560px;
      }

      .studio-menu {
        border-right: 2px solid #10251f;
        background: #f9faf4;
        padding: 14px;
      }

      .menu-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 34px;
        margin-bottom: 8px;
        padding: 0 10px;
        border-radius: 8px;
        color: #30453e;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.86rem;
        font-weight: 700;
      }

      .menu-item.active {
        border: 1px solid #10251f;
        background: #d8b45f;
        color: #10251f;
      }

      .studio-main {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(190px, 0.62fr);
        gap: 12px;
        padding: 14px;
        background: #ffffff;
      }

      .studio-pane {
        border: 1px solid rgba(16, 37, 31, 0.28);
        border-radius: 8px;
        background: #fbfcf7;
        overflow: hidden;
      }

      .studio-pane-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgba(16, 37, 31, 0.18);
        padding: 10px 12px;
        color: #30453e;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.76rem;
        font-weight: 800;
        text-transform: uppercase;
      }

      .studio-pane-body {
        padding: 12px;
      }

      .provider-row {
        display: grid;
        grid-template-columns: 90px 1fr;
        gap: 10px;
        align-items: start;
        padding: 11px 0;
        border-bottom: 1px solid rgba(16, 37, 31, 0.14);
      }

      .provider-row:last-child {
        border-bottom: 0;
      }

      .provider-name {
        display: flex;
        align-items: center;
        gap: 8px;
        color: #10251f;
        font-size: 0.9rem;
        font-weight: 850;
      }

      .provider-name img {
        width: 22px;
        height: 22px;
        object-fit: contain;
      }

      .provider-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        min-height: 24px;
        padding: 0 8px;
        border-radius: 6px;
        background: #e7f1ea;
        color: #244f43;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.72rem;
        font-weight: 800;
      }

      .tag.red {
        background: #f7e7df;
        color: #7c331e;
      }

      .tag.blue {
        background: #e6eefb;
        color: #254b93;
      }

      .meter-row {
        display: grid;
        grid-template-columns: 84px 1fr 54px;
        gap: 8px;
        align-items: center;
        margin-bottom: 12px;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.76rem;
      }

      .meter {
        height: 8px;
        border-radius: 999px;
        background: #dfe5dc;
        overflow: hidden;
      }

      .meter span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: #2f7d69;
      }

      .tool-log {
        display: grid;
        gap: 8px;
        margin-top: 14px;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.76rem;
      }

      .tool-log div {
        padding: 8px;
        border-radius: 6px;
        background: #101312;
        color: #e8ede4;
      }

      .below-hero {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        padding-top: 0;
      }

      .signal {
        min-height: 116px;
        border: 1px solid rgba(16, 37, 31, 0.2);
        border-radius: 8px;
        background: #ffffff;
        padding: 18px;
      }

      .signal strong {
        display: block;
        margin-bottom: 8px;
        color: #10251f;
        font-size: 1rem;
      }

      .signal span {
        color: #587067;
        font-size: 0.92rem;
        line-height: 1.5;
      }

      .section-kicker {
        margin-bottom: 16px;
        color: #2f7d69;
        font-size: 0.82rem;
        font-weight: 850;
        text-transform: uppercase;
      }

      h2 {
        max-width: 760px;
        font-size: 3rem;
        font-weight: 850;
        line-height: 1.04;
        letter-spacing: 0;
      }

      .section-intro {
        max-width: 760px;
        margin-top: 18px;
        color: #30453e;
        font-size: 1.08rem;
        line-height: 1.7;
      }

      .workflows {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
        margin-top: 36px;
      }

      .workflow {
        min-height: 220px;
        border: 2px solid #10251f;
        border-radius: 8px;
        background: #ffffff;
        padding: 20px;
        box-shadow: 6px 6px 0 #d8b45f;
      }

      .workflow h3 {
        margin-bottom: 14px;
        font-size: 1.1rem;
        font-weight: 850;
      }

      .workflow p {
        color: #30453e;
        font-size: 0.96rem;
        line-height: 1.62;
      }

      .capability-band {
        background: #10251f;
        color: #f6f7f2;
      }

      .capability-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
        gap: 42px;
        align-items: center;
      }

      .capability-band .section-kicker {
        color: #d8b45f;
      }

      .capability-band .section-intro {
        color: #c7d5ce;
      }

      .flag-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }

      .flag {
        display: flex;
        align-items: center;
        min-height: 46px;
        border: 1px solid rgba(246, 247, 242, 0.22);
        border-radius: 8px;
        background: rgba(246, 247, 242, 0.07);
        padding: 0 12px;
        color: #f6f7f2;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.84rem;
      }

      .linear-board {
        display: grid;
        grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
        gap: 24px;
        margin-top: 42px;
        align-items: stretch;
      }

      .linear-list {
        display: grid;
        gap: 12px;
      }

      .linear-step {
        display: grid;
        grid-template-columns: 44px 1fr;
        gap: 14px;
        align-items: start;
        border: 1px solid rgba(16, 37, 31, 0.18);
        border-radius: 8px;
        background: #ffffff;
        padding: 16px;
      }

      .step-index {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 8px;
        background: #2f7d69;
        color: #ffffff;
        font-weight: 850;
      }

      .linear-step strong {
        display: block;
        margin-bottom: 5px;
      }

      .linear-step p {
        color: #587067;
        font-size: 0.94rem;
        line-height: 1.55;
      }

      .delivery-console {
        border: 2px solid #10251f;
        border-radius: 8px;
        background: #101312;
        color: #e8ede4;
        overflow: hidden;
      }

      .delivery-console pre {
        margin: 0;
        overflow-x: auto;
        padding: 20px;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.88rem;
        line-height: 1.8;
        white-space: pre-wrap;
      }

      .install {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(320px, 0.68fr);
        gap: 28px;
        align-items: start;
      }

      .install-panel {
        border: 2px solid #10251f;
        border-radius: 8px;
        background: #ffffff;
        overflow: hidden;
      }

      .install-panel pre {
        margin: 0;
        padding: 20px;
        overflow-x: auto;
        font-family: var(--font-geist-mono), ui-monospace, monospace;
        font-size: 0.9rem;
        line-height: 1.75;
        white-space: pre-wrap;
      }

      .facts {
        display: grid;
        gap: 12px;
      }

      .fact {
        border: 1px solid rgba(16, 37, 31, 0.18);
        border-radius: 8px;
        background: #ffffff;
        padding: 16px;
      }

      .fact strong {
        display: block;
        margin-bottom: 6px;
      }

      .fact span {
        color: #587067;
        font-size: 0.93rem;
        line-height: 1.5;
      }

      .footer {
        border-top: 1px solid rgba(16, 37, 31, 0.16);
        padding: 34px 24px;
        color: #587067;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        max-width: 1180px;
        margin: 0 auto;
        font-size: 0.92rem;
      }

      .footer-links {
        display: flex;
        gap: 18px;
        font-weight: 750;
      }

      .stagger-fade,
      .stagger-fade-group > * {
        --stagger-fade-y: 12px;
      }

      @media (max-width: 1020px) {
        .hero-grid,
        .capability-grid,
        .linear-board,
        .install {
          grid-template-columns: 1fr;
        }

        .hero-grid {
          min-height: auto;
          padding-top: 58px;
        }

        .studio-frame {
          max-width: 720px;
        }

        .below-hero,
        .workflows {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        h1 {
          font-size: 3.7rem;
        }

        h2 {
          font-size: 2.55rem;
        }
      }

      @media (max-width: 720px) {
        .nav-inner {
          height: auto;
          min-height: 64px;
          align-items: flex-start;
          flex-direction: column;
          gap: 12px;
          padding: 14px 18px;
        }

        .nav-links {
          width: 100%;
          justify-content: space-between;
          gap: 10px;
          font-size: 0.85rem;
        }

        .section {
          padding: 70px 18px;
        }

        .hero-grid {
          padding: 42px 18px 58px;
        }

        h1 {
          font-size: 2.65rem;
          line-height: 1.02;
        }

        h2 {
          font-size: 2rem;
        }

        .hero-copy,
        .section-intro {
          font-size: 1rem;
        }

        .studio-layout,
        .studio-main {
          grid-template-columns: 1fr;
        }

        .studio-menu {
          border-right: 0;
          border-bottom: 2px solid #10251f;
        }

        .below-hero,
        .workflows,
        .flag-grid {
          grid-template-columns: 1fr;
        }

        .studio-layout {
          min-height: auto;
        }

        .footer-inner {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-shell">
      <header class="nav">
        <div class="nav-inner">
          <a class="brand" href={pageUrl} aria-label="Amon Hen home">
            <span class="brand-mark">AH</span>
            <span>{siteName}</span>
          </a>
          <nav class="nav-links" aria-label="Primary navigation">
            <a href="#studio">Studio</a>
            <a href="#capabilities">Capabilities</a>
            <a href="#linear">Linear</a>
            <a href="#run">Run</a>
          </nav>
        </div>
      </header>

      <main>
        <section class="hero">
          <div class="hero-grid">
            <div class="stagger-fade-group">
              <div class="eyebrow">Rust-native agent command center</div>
              <h1>{siteName}</h1>
              <p class="hero-copy">
                Amon Hen coordinates Codex, Claude, Gemini, and Linear from one native terminal. Pick a planner, appoint a lead, hand work between providers, fan out real same-provider sub-agents, and keep the loop running until review or passing CI.
              </p>
              <div class="hero-actions">
                <a class="button primary" href="#run">Run the Studio</a>
                <a class="button secondary" href={docsUrl} target="_blank" rel="noreferrer">Read CLI docs</a>
              </div>
              <div class="command" aria-label="Example command">
                <div class="command-title">
                  <span>terminal</span>
                  <span>{examplePrompt}</span>
                </div>
                <pre><code>cargo run -p council -- --studio --members codex,claude,gemini</code></pre>
              </div>
            </div>

            <div class="studio-frame stagger-fade" id="studio">
              <div class="studio-topbar">
                <span>Amon Hen Studio</span>
                <span class="studio-status">interactive</span>
              </div>
              <div class="studio-layout">
                <aside class="studio-menu" aria-label="Studio menu preview">
                  <div class="menu-item active">Settings <span>enter</span></div>
                  <div class="menu-item">Agents <span>3</span></div>
                  <div class="menu-item">Linear <span>on</span></div>
                  <div class="menu-item">Auth <span>tabs</span></div>
                  <div class="menu-item">Files <span>@</span></div>
                  <div class="menu-item">Tools <span>logs</span></div>
                  <div class="menu-item">Help <span>?</span></div>
                </aside>
                <div class="studio-main">
                  <section class="studio-pane">
                    <div class="studio-pane-title">
                      <span>Providers</span>
                      <span>lead: claude</span>
                    </div>
                    <div class="studio-pane-body">
                      {providerRows.map(([name, logo, role, model, effort, capability], index) => (
                        <div class="provider-row">
                          <div class="provider-name">
                            <img src={logo} alt={`${name} logo`} />
                            <span>{name}</span>
                          </div>
                          <div class="provider-meta">
                            <span class:list={["tag", index === 1 && "red", index === 2 && "blue"]}>{role}</span>
                            <span class="tag">{model}</span>
                            <span class="tag">{effort}</span>
                            <span class:list={["tag", index === 1 && "red", index === 2 && "blue"]}>{capability}</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </section>
                  <section class="studio-pane">
                    <div class="studio-pane-title">
                      <span>Telemetry</span>
                      <span>live</span>
                    </div>
                    <div class="studio-pane-body">
                      <div class="meter-row"><span>codex</span><div class="meter"><span style="width: 72%"></span></div><span>18k</span></div>
                      <div class="meter-row"><span>claude</span><div class="meter"><span style="width: 84%"></span></div><span>24k</span></div>
                      <div class="meter-row"><span>gemini</span><div class="meter"><span style="width: 58%"></span></div><span>13k</span></div>
                      <div class="tool-log">
                        <div>$ git status --short</div>
                        <div>$ cargo test --workspace</div>
                        <div>Linear: attach media + comment</div>
                      </div>
                    </div>
                  </section>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section below-hero" aria-label="Project signals">
          <div class="signal">
            <strong>Native Rust</strong>
            <span>No tracked npm CLI core. The orchestration path is a Cargo workspace and native binary.</span>
          </div>
          <div class="signal">
            <strong>Provider control</strong>
            <span>Model, effort, auth, sandbox, MCP, Skills, tools, and permission controls per provider.</span>
          </div>
          <div class="signal">
            <strong>Studio UI</strong>
            <span>Selectable panes, settings, help, auth onboarding, Linear management, files, and command tools.</span>
          </div>
          <div class="signal">
            <strong>Delivery loop</strong>
            <span>Project and epic polling, isolated workspaces, retries, reconciliation, and review or CI gates.</span>
          </div>
        </section>

        <section class="section">
          <div class="section-kicker">What changed</div>
          <h2>A control plane for actual agent work, not just answer comparison.</h2>
          <p class="section-intro">
            Amon Hen keeps the useful parts of consulting multiple models, then adds the work surfaces the project needs: social login bootstrap, provider capability management, local file tagging, shell command visibility, media attachments, Linear execution loops, and token/tool telemetry that stays visible while agents run.
          </p>
          <div class="workflows">
            {workflowCards.map(([heading, body]) => (
              <article class="workflow">
                <h3>{heading}</h3>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="capability-band" id="capabilities">
          <div class="section capability-grid">
            <div>
              <div class="section-kicker">Provider capabilities</div>
              <h2>Inherit the local CLI. Override the exact pieces you need.</h2>
              <p class="section-intro">
                Codex, Claude, and Gemini each have their own auth story, MCP surface, tool policy, and config files. Amon Hen exposes those differences instead of flattening them away, so Studio and CLI runs can switch between inherited provider config and task-specific overrides.
              </p>
            </div>
            <div class="flag-grid" aria-label="Provider capability flags">
              {capabilityFlags.map((flag) => <div class="flag">{flag}</div>)}
            </div>
          </div>
        </section>

        <section class="section" id="linear">
          <div class="section-kicker">Linear autonomous delivery</div>
          <h2>Point it at a project or epic and keep the loop moving.</h2>
          <p class="section-intro">
            Amon Hen can poll Linear, pick eligible work, allocate planner/lead/executor phases, create isolated workspaces, run provider teams, attach generated media, update tickets, and reconcile retries until the configured completion gate is met.
          </p>
          <div class="linear-board">
            <div class="linear-list">
              {linearSteps.map(([heading, body], index) => (
                <article class="linear-step">
                  <div class="step-index">{index + 1}</div>
                  <div>
                    <strong>{heading}</strong>
                    <p>{body}</p>
                  </div>
                </article>
              ))}
            </div>
            <div class="delivery-console" aria-label="Linear delivery command">
              <pre><code>council \
  --deliver-linear \
  --linear-project ENG \
  --linear-until-complete \
  --linear-completion-gate review-or-ci \
  --members codex,claude,gemini \
  --planner codex \
  --lead claude \
  --team-work 2</code></pre>
            </div>
          </div>
        </section>

        <section class="section install" id="run">
          <div>
            <div class="section-kicker">Run it locally</div>
            <h2>The project ships as a Rust CLI with a native Studio.</h2>
            <p class="section-intro">
              Install from the checkout, confirm provider auth, then run the interactive Studio or a scripted delivery command. Social login flows can open browser tabs and return through code paste or deeplink, depending on the provider.
            </p>
            <div class="install-panel" aria-label="Install commands">
              <pre><code>cargo install --path crates/council
council --auth-status --capabilities-status
council --studio --members codex,claude,gemini
council --members codex,claude,gemini --team-work 2 "Inspect this repo"</code></pre>
            </div>
          </div>
          <div class="facts">
            <div class="fact">
              <strong>Binary</strong>
              <span>`council` remains the compatibility command while the project identity moves to Amon Hen.</span>
            </div>
            <div class="fact">
              <strong>Website</strong>
              <span>Built from scratch for this rewrite and deployed as a Cloudflare Worker on `amonhen.legit.place`.</span>
            </div>
            <div class="fact">
              <strong>Repository</strong>
              <span>Main development lives in the Dviros fork, with upstream kept only as inspiration and lineage.</span>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div class="footer-inner">
          <span>Amon Hen is an independent Rust-native AI delivery studio by Dviros.</span>
          <div class="footer-links">
            <a href={repoUrl} target="_blank" rel="noreferrer">GitHub</a>
            <a href={docsUrl} target="_blank" rel="noreferrer">Docs</a>
            <a href={crateUrl} target="_blank" rel="noreferrer">Crate</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
